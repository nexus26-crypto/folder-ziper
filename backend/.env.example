# ============ App ============
APP_ENV=production
APP_NAME=VyntrixSync
DOMAIN=app.seudominio.com
FRONTEND_URL=https://app.seudominio.com

# CORS (separado por vírgula). Em dev: http://localhost:5173,http://localhost:8080
CORS_ORIGINS=https://app.seudominio.com

# ============ Segurança ============
# Gere com: openssl rand -hex 64
JWT_SECRET=troque_esse_valor_por_um_hex_de_64_bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============ Postgres ============
POSTGRES_USER=vyntrix
POSTGRES_PASSWORD=troque_essa_senha
POSTGRES_DB=vyntrix
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============ Redis ============
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============ Flower (monitor Celery) ============
FLOWER_USER=admin
FLOWER_PASSWORD=troque_essa_senha

# ============ Primeiro admin (criado no bootstrap) ============
BOOTSTRAP_ADMIN_EMAIL=admin@seudominio.com
BOOTSTRAP_ADMIN_PASSWORD=troque_no_primeiro_login
TMDB_API_KEY=
